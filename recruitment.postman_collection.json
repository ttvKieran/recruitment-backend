        {
          "name": "Nộp hồ sơ",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const createJobReq = {\r",
                  "    url: pm.environment.get(\"base_url\") + \"/api/v1/job-service/job-positions\",\r",
                  "    method: 'POST',\r",
                  "    header: {\r",
                  "        'Content-Type': 'application/json',\r",
                  "        'Authorization': 'Bearer ' + pm.collectionVariables.get(\"access_token\")\r",
                  "    },\r",
                  "    body: {\r",
                  "        mode: 'raw',\r",
                  "        raw: JSON.stringify({\r",
                  "            title: \"Job Nháp Automation Test\",\r",
                  "            recruitmentRequestId: 1, \r",
                  "            quantity: 1\r",
                  "        })\r",
                  "    }\r",
                  "};\r",
                  "\r",
                  "pm.sendRequest(createJobReq, function (err, res) {\r",
                  "    if (!err && res.code === 200) {\r",
                  "        let jobId = res.json().data.id;\r",
                  "        pm.variables.set(\"temp_job_id\", jobId); // Lưu vào local variable\r",
                  "        console.log(\"Pre-condition: Đã tạo Job nháp ID = \" + jobId);\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if(pm.response.code === 200 || pm.response.code === 201) {\r",
                  "    let candidateId = pm.response.json().id;\r",
                  "    pm.variables.set(\"temp_candidate_id\", candidateId);\r",
                  "    \r",
                  "    // 1. Dọn dẹp Candidate \r",
                  "    pm.sendRequest({\r",
                  "        url: pm.environment.get(\"base_url\") + \"/api/v1/candidate-service/candidates/\" + candidateId,\r",
                  "        method: 'DELETE',\r",
                  "        header: { 'Authorization': 'Bearer ' + pm.collectionVariables.get(\"access_token\") }\r",
                  "    }, function(err, res) {\r",
                  "        console.log(\"Cleanup: Đã xóa Candidate nháp.\");\r",
                  "        \r",
                  "        // 2. Dọn dẹp Job Position\r",
                  "        let tempJobId = pm.variables.get(\"temp_job_id\");\r",
                  "        pm.sendRequest({\r",
                  "            url: pm.environment.get(\"base_url\") + \"/api/v1/job-service/job-positions/\" + tempJobId,\r",
                  "            method: 'DELETE',\r",
                  "            header: { 'Authorization': 'Bearer ' + pm.collectionVariables.get(\"access_token\") }\r",
                  "        }, function(err2, res2) {\r",
                  "            console.log(\"Cleanup: Đã xóa Job nháp. Môi trường DB sạch sẽ.\");\r",
                  "        });\r",
                  "    });\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
