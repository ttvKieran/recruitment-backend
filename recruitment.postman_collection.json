    {
      "name": "candidate-service",
      "item": [
        {
          "name": "update status candidate",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Đọc trạng thái từ request params\r",
                  "let requestedStatus = pm.request.url.query.get(\"status\");\r",
                  "\r",
                  "if (pm.response.code === 200) {\r",
                  "    if (requestedStatus === \"REJECTED\") {\r",
                  "        console.log(\"HR đánh trượt ứng viên -> Chuyển luồng sang gửi email báo buồn.\");\r",
                  "        pm.execution.setNextRequest(\"Gửi email từ chối\"); \r",
                  "    } \r",
                  "    else if (requestedStatus === \"INTERVIEW\") {\r",
                  "        console.log(\"Tuyệt vời! Ứng viên pass hồ sơ -> Chuyển sang luồng tạo lịch phỏng vấn.\");\r",
                  "        pm.execution.setNextRequest(\"Lên lịch phỏng vấn\"); \r",
                  "    }\r",
                  "} else {\r",
                  "    // Nếu cập nhật lỗi (ví dụ sai trạng thái business logic)\r",
                  "    console.error(\"Lỗi chuyển trạng thái. Dừng workflow.\");\r",
                  "    pm.execution.setNextRequest(null);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Lấy data candidate\r",
                  "const getCandidateReq = {\r",
                  "    url: pm.environment.get(\"base_url\") + \"/api/v1/candidate-service/candidates?page=1&limit=1\",\r",
                  "    method: 'GET',\r",
                  "    header: {\r",
                  "        'Authorization': 'Bearer ' + pm.collectionVariables.get(\"access_token\")\r",
                  "    }\r",
                  "};\r",
                  "\r",
                  "pm.sendRequest(getCandidateReq, function (err, res) {\r",
                  "    if (!err && res.code === 200) {\r",
                  "        let candidateList = res.json().data.result; \r",
                  "        \r",
                  "        if (candidateList && candidateList.length > 0) {\r",
                  "            let firstCandidate = candidateList[0];\r",
                  "            pm.variables.set(\"candidate_id\", firstCandidate.id);\r",
                  "            pm.variables.set(\"candidate_name\", firstCandidate.name);\r",
                  "            pm.variables.set(\"candidate_email\", firstCandidate.email);\r",
                  "            \r",
                  "            console.log(\"Pre-request Dynamic Data: Nạp thông tin ứng viên số \" + firstCandidate.id);\r",
                  "        }\r",
                  "    } else {\r",
                  "        console.error(\"Lỗi lấy dữ liệu ứng viên trong Pre-request\");\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"username\": \"admin@gmail.com\",\r\n  \"password\": \"12345\"\r\n}",
              "options": {
